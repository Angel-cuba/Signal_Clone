rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Fields any authenticated user may freely update on a chat document.
    // Typing indicators (typingUsers, typingNames) and read receipts (lastRead)
    // are written by ALL participants — not just the chat creator.
    function isPresenceUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      // Only the three presence keys may be touched
      return changed.hasOnly(['typingUsers', 'typingNames', 'lastRead'])
        // Each key that IS being changed must be a map (prevents scalar injection)
        && (!changed.hasAll(['typingUsers']) || request.resource.data.typingUsers is map)
        && (!changed.hasAll(['typingNames']) || request.resource.data.typingNames is map)
        && (!changed.hasAll(['lastRead'])    || request.resource.data.lastRead    is map);
    }

    // A user may append their own UID to the members[] array (used by Cloud Functions
    // to identify push notification recipients). Constraints:
    //   • Only the members field may change
    //   • members must remain a list
    //   • The list may only grow (no removals)
    //   • The only new entry must be the caller's own UID
    function isMemberJoin() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let after  = request.resource.data.members;
      let before = resource.data.get('members', []);
      return changed.hasOnly(['members', 'typingUsers', 'typingNames', 'lastRead'])
        && after is list
        && after.size() == before.size() + 1
        && after.hasAll(before)
        && after.hasAll([request.auth.uid]);
    }

    match /chat/{chatId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
                    && request.resource.data.chatName is string
                    && request.resource.data.chatName.size() > 0
                    && request.resource.data.chatName.size() <= 50
                    && request.resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated() && isOwner(resource.data.userId);

      // Owner may update anything; any authenticated user may update only
      // presence fields (typing/read receipts) or append their own UID to members[].
      allow update: if isAuthenticated()
                    && (isOwner(resource.data.userId) || isPresenceUpdate() || isMemberJoin());

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
                      && request.resource.data.email == request.auth.token.email
                      && request.resource.data.message is string
                      && request.resource.data.message.size() > 0
                      && request.resource.data.message.size() <= 2000;
        // uid is preferred (stored since Phase 4 self-review fix);
        // email fallback retains delete rights for messages written before the uid field was added.
        allow delete: if isAuthenticated()
                      && (resource.data.uid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
        allow update: if false; // messages are immutable
      }
    }

    // Users collection: stores push tokens and profile metadata.
    // Each user can only read and write their own document.
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
  }
}
